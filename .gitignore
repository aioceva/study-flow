# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# sensitive files — НЕ commit-вай
Anthropic*
*.txt

# Claude Code settings
.claude/

# Документация — не в репото (с изключение на docs/context/ и CLAUDE.md)
*.md
!CLAUDE.md
!docs/context/*.md
